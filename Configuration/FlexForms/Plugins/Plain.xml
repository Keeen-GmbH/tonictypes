<T3DataStructure>
  <meta>
    <langDisable>1</langDisable>
  </meta>
  <sheets>
    <general_settings>
      <ROOT>
          <sheetTitle>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.general_settings</sheetTitle>
        <type>array</type>
        <el>
          <settings.logo>
              <label></label>
              <config>
                <type>user</type>
                <userFunc>K3n\Tonictypes\UserFunc\Logo->displayLogoText</userFunc>
              </config>
          </settings.logo>
          <settings.detail_pid>
            <title>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.detail_page_id</title>
            <section>1</section>
            <type>array</type>
            <el>
              <pageids>
                <type>array</type>
                <title></title>
                <el>
                  <info>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.available_markers</label>
                      <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayAvailableMarkers</userFunc>
                        <parameters>
                          <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/AvailableMarkers.html</template>
                          <envVariables>1</envVariables>
                        </parameters>
                      </config>
                  </info>
                  <pageid>
                      <label>{detailPid}</label>
                      <exclude>1</exclude>
                      <config>
                        <type>input</type>
                        <renderType>inputLink</renderType>
                        <size>30</size>
                        <eval>trim</eval>
                        <fieldControl>
                          <linkPopup>
                            <options>
                              <allowedLinkOptions>page</allowedLinkOptions>
                            </options>
                          </linkPopup>
                        </fieldControl>
                      </config>
                  </pageid>
                  <condition>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.activate_condition</label>
                      <description>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.empty_condition_is_active</description>
                      <config>
                        <type>input</type>
                        <size>50</size>
                        <placeholder>{variableFromGetParameter} = 'xyz'</placeholder>
                      </config>
                  </condition>
                </el>
              </pageids>
            </el>
          </settings.detail_pid>
        </el>
      </ROOT>
    </general_settings>
    <template_settings>
      <ROOT>
          <sheetTitle>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.template_settings</sheetTitle>
        <type>array</type>
        <el>
          <settings.template_selection>
              <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.template_selection</label>
              <onChange>reload</onChange>
              <config type="array">
                <type>select</type>
                <renderType>selectSingle</renderType>
                <items type="array">
                  <numIndex index="0" type="array">
                    <numIndex index="0">LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.debug_template</numIndex>
                    <numIndex index="1"></numIndex>
                  </numIndex>
                  <numIndex index="1" type="array">
                    <numIndex index="0">LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.custom_template_path</numIndex>
                    <numIndex index="1">CUSTOM</numIndex>
                  </numIndex>
                  <numIndex index="2" type="array">
                    <numIndex index="0">LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.custom_fluid_code</numIndex>
                    <numIndex index="1">FLUID</numIndex>
                  </numIndex>
                </items>
                <multiple>0</multiple>
                <itemsProcFunc>K3n\Tonictypes\UserFunc\Template->populateTemplates</itemsProcFunc>
                <maxitems>1</maxitems>
                <minitems>1</minitems>
                <size>1</size>
                <fieldWizard>
                  <selectIcons>
                    <disabled>0</disabled>
                  </selectIcons>
                </fieldWizard>
              </config>
          </settings.template_selection>
          <settings.fluid_code>
              <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.fluid</label>
              <displayCond>FIELD:settings.template_selection:=:FLUID</displayCond>
              <config>
                <type>text</type>
                <renderType>t3editor</renderType>
                <format>html</format>
                <rows>15</rows>
              </config>
          </settings.fluid_code>
          <settings.template_override>
              <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.template_override</label>
              <displayCond>FIELD:settings.template_selection:=:CUSTOM</displayCond>
              <config type="array">
                <type>inline</type>
                <maxitems>1</maxitems>
                <minitems>1</minitems>
                <foreign_table>sys_file_reference</foreign_table>
                <foreign_field>uid_foreign</foreign_field>
                <foreign_sortby>sorting_foreign</foreign_sortby>
                <foreign_table_field>tablenames</foreign_table_field>
                <foreign_match_fields>
                  <!-- this will be stored in sys_file_reference.fieldname -->
                  <fieldname>template_override</fieldname>
                </foreign_match_fields>
                <foreign_label>uid_local</foreign_label>
                <foreign_selector>uid_local</foreign_selector>
                <overrideChildTca>
                  <columns>
                    <uid_local>
                      <config>
                        <appearance>
                          <elementBrowserType>file</elementBrowserType>
                          <elementBrowserAllowed>html</elementBrowserAllowed>
                        </appearance>
                      </config>
                    </uid_local>
                  </columns>
                </overrideChildTca>
                <filter>
                  <userFunc>TYPO3\CMS\Core\Resource\Filter\FileExtensionFilter->filterInlineChildren</userFunc>
                  <parameters>
                    <allowedFileExtensions>html</allowedFileExtensions>
                    <disallowedFileExtensions>*</disallowedFileExtensions>
                  </parameters>
                </filter>
                <appearance>
                  <useSortable>0</useSortable>
                  <enabledControls>
                    <info>1</info>
                    <new>0</new>
                    <dragdrop>1</dragdrop>
                    <sort>0</sort>
                    <hide>1</hide>
                    <delete>1</delete>
                  </enabledControls>
                </appearance>
              </config>
          </settings.template_override>
          <settings.render_only_template>
              <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.render_only_template</label>
              <config>
                <checkbox>1</checkbox>
                <type>check</type>
              </config>
          </settings.render_only_template>
          <settings.template_switch>
            <title>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.template_switch</title>
            <section>1</section>
            <type>array</type>
            <el>
              <switches>
                <type>array</type>
                <title></title>
                <el>
                  <info>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.available_markers</label>
                      <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayAvailableMarkers</userFunc>
                        <parameters>
                          <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/AvailableMarkers.html</template>
                          <envVariables>1</envVariables>
                        </parameters>
                      </config>
                  </info>
                  <template_selection>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.template_selection</label>
                      <onChange>reload</onChange>
                      <config type="array">
                        <type>select</type>
                        <renderType>selectSingle</renderType>
                        <items type="array">
                          <numIndex index="0" type="array">
                            <numIndex index="0">LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.custom_fluid_code</numIndex>
                            <numIndex index="1">FLUID</numIndex>
                          </numIndex>
                        </items>
                        <multiple>0</multiple>
                        <itemsProcFunc>K3n\Tonictypes\UserFunc\Template->populateTemplates</itemsProcFunc>
                        <maxitems>1</maxitems>
                        <minitems>1</minitems>
                        <size>1</size>
                      </config>
                  </template_selection>
                  <fluid_code>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.fluid</label>
                      <displayCond>FIELD:template_selection:=:FLUID</displayCond>
                      <config>
                        <type>text</type>
                        <renderType>t3editor</renderType>
                        <format>html</format>
                        <rows>15</rows>
                      </config>
                  </fluid_code>
                  <condition>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.fluid_condition</label>
                      <description>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.empty_condition_is_active</description>
                      <config>
                        <type>input</type>
                        <size>150</size>
                        <placeholder><![CDATA[{yourVariable} == '1337']]></placeholder>
                      </config>
                  </condition>
                  <render_only_template>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.render_only_template</label>
                      <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                      </config>
                  </render_only_template>
                </el>
              </switches>
            </el>
          </settings.template_switch>
          <settings.variables>
              <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.variable_injection</label>
              <config>
                <type>group</type>
                <internal_type>db</internal_type>
                <multiple>0</multiple>
                <autosizemax>10</autosizemax>
                <items type="array"></items>
                <allowed>tx_tonictypes_domain_model_variable</allowed>
                <maxitems>99999</maxitems>
                <minitems>0</minitems>
                <size>5</size>
              </config>
          </settings.variables>
        </el>
      </ROOT>
    </template_settings>
    <developer_settings>
      <ROOT>
          <sheetTitle>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.developer_settings</sheetTitle>
        <type>array</type>
        <el>
          <settings.static_cache>
              <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.static_cache</label>
              <config>
                <checkbox>1</checkbox>
                <type>check</type>
              </config>
          </settings.static_cache>
          <settings.custom_headers>
            <title>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.custom_headers</title>
            <section>1</section>
            <type>array</type>
            <el>
              <headers>
                <type>array</type>
                <title></title>
                <el>
                  <info>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.available_markers</label>
                      <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayAvailableMarkers</userFunc>
                        <parameters>
                          <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/AvailableMarkers.html</template>
                          <envVariables>1</envVariables>
                        </parameters>
                      </config>
                  </info>
                  <name>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.header_name</label>
                      <config>
                        <type>input</type>
                        <size>50</size>
                        <placeholder>Content-Type</placeholder>
                      </config>
                  </name>
                  <value>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.header_value</label>
                      <config>
                        <type>input</type>
                        <size>50</size>
                        <placeholder>text/html; charset=utf-8</placeholder>
                      </config>
                  </value>
                  <condition>
                      <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.fluid_condition</label>
                      <description>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.empty_condition_is_active</description>
                      <config>
                        <type>input</type>
                        <size>150</size>
                        <placeholder><![CDATA[{yourVariable} == '1337']]></placeholder>
                      </config>
                  </condition>
                </el>
              </headers>
            </el>
          </settings.custom_headers>
        </el>
      </ROOT>
    </developer_settings>
  </sheets>
</T3DataStructure>
