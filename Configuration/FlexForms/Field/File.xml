<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                    <label></label>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Text->displayTemplate</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/FieldConfiguration/Notice.html</template>
                        </parameters>
                    </config>
            </info>
            <internal_type>
                    <label>internal_type</label>
                    <onChange>reload</onChange>
                    <config>
                        <type>select</type>
                        <renderType>selectSingle</renderType>
                        <multiple>0</multiple>
                        <autosizemax>1</autosizemax>
                        <items type="array">
                            <numIndex index="0" type="array">
                                <numIndex index="0">file</numIndex>
                                <numIndex index="1">file</numIndex>
                            </numIndex>
                            <numIndex index="1" type="array">
                                <numIndex index="0">file_reference</numIndex>
                                <numIndex index="1">file_reference</numIndex>
                            </numIndex>
                        </items>
                        <maxitems>1</maxitems>
                        <minitems>1</minitems>
                        <size>1</size>
                    </config>
            </internal_type>
            <size>
                    <label>size</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>1</default>
                    </config>
            </size>
            <allowed>
                    <label>allowed</label>
                    <config>
                        <type>input</type>
                        <size>15</size>
                    </config>
            </allowed>
            <disallowed>
                    <label>disallowed</label>
                    <config>
                        <type>input</type>
                        <size>15</size>
                        <default>*</default>
                    </config>
            </disallowed>
            <uploadfolder>
                    <label>uploadfolder</label>
                    <displayCond>FIELD:internal_type:=:file</displayCond>
                    <config>
                        <type>input</type>
                        <size>15</size>
                        <placeholder>fileadmin/upload/</placeholder>
                    </config>
            </uploadfolder>
            <max_size>
                    <label>max_size</label>
                    <config>
                        <type>input</type>
                        <size>15</size>
                    </config>
            </max_size>
            <show_thumbs>
                    <label>show_thumbs</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </show_thumbs>
            <selectedListStyle>
                    <label>selectedListStyle</label>
                    <config>
                        <type>input</type>
                        <size>15</size>
                    </config>
            </selectedListStyle>
            <multiple>
                    <label>multiple</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </multiple>
            <hideMoveIcons>
                    <label>hideMoveIcons</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </hideMoveIcons>
            <minitems>
                    <label>minitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>0</default>
                    </config>
            </minitems>
            <maxitems>
                    <label>maxitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>999</default>
                    </config>
            </maxitems>
            <disable_controls>
                    <label>disable_controls</label>
                    <config>
                        <type>select</type>
                        <renderType>selectMultipleSideBySide</renderType>
                        <multiple>0</multiple>
                        <autosizemax>5</autosizemax>
                        <items type="array">
                            <numIndex index="0" type="array">
                                <numIndex index="0">browser</numIndex>
                                <numIndex index="1">browser</numIndex>
                            </numIndex>
                            <numIndex index="1" type="array">
                                <numIndex index="0">list</numIndex>
                                <numIndex index="1">list</numIndex>
                            </numIndex>
                            <numIndex index="2" type="array">
                                <numIndex index="0">upload</numIndex>
                                <numIndex index="1">upload</numIndex>
                            </numIndex>
                            <numIndex index="3" type="array">
                                <numIndex index="0">delete</numIndex>
                                <numIndex index="1">delete</numIndex>
                            </numIndex>
                        </items>
                        <maxitems>9999</maxitems>
                        <minitems>0</minitems>
                        <size>5</size>
                    </config>
            </disable_controls>
        </el>
    </ROOT>
</T3DataStructure>
