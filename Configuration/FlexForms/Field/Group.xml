<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                    <label></label>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                        </parameters>
                    </config>
            </info>
            <internal_type>
                    <label>internal_type</label>
                    <onChange>reload</onChange>
                    <config>
                        <type>select</type>
                        <renderType>selectSingle</renderType>
                        <multiple>0</multiple>
                        <items type="array">
                            <numIndex index="2" type="array">
                                <numIndex index="0">folder</numIndex>
                                <numIndex index="1">folder</numIndex>
                            </numIndex>
                            <numIndex index="3" type="array">
                                <numIndex index="0">db</numIndex>
                                <numIndex index="1">db</numIndex>
                            </numIndex>
                        </items>
                        <maxitems>1</maxitems>
                        <minitems>0</minitems>
                        <size>1</size>
                    </config>
            </internal_type>
            <allowed>
                    <label>allowed</label>
                    <config>
                        <type>input</type>
                        <size>30</size>
                        <eval>trim</eval>
                    </config>
            </allowed>
            <disallowed>
                    <label>disallowed</label>
                    <config>
                        <type>input</type>
                        <size>15</size>
                        <default>*</default>
                    </config>
            </disallowed>
            <minitems>
                    <label>minitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>0</default>
                    </config>
            </minitems>
            <maxitems>
                    <label>maxitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>1</default>
                    </config>
            </maxitems>
            <size>
                    <label>size</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>1</default>
                    </config>
            </size>
            <hideMoveIcons>
                    <label>hideMoveIcons</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </hideMoveIcons>
            <multiple>
                    <label>multiple</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </multiple>
            <uploadfolder>
                    <label>uploadfolder</label>
                    <displayCond>FIELD:internal_type:=:file</displayCond>
                    <config>
                        <type>input</type>
                        <size>15</size>
                        <eval>trim</eval>
                    </config>
            </uploadfolder>
        </el>
    </ROOT>
</T3DataStructure>
