<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                    <label></label>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                        </parameters>
                    </config>
            </info>
            <eval>
                    <label>eval</label>
                    <onChange>reload</onChange>
                    <config>
                        <type>select</type>
                        <renderType>selectMultipleSideBySide</renderType>
                        <multiple>0</multiple>
                        <autosizemax>5</autosizemax>
                        <items type="array">
                            <!--
                            <numIndex index="14" type="array">
                                <numIndex index="0">required</numIndex>
                                <numIndex index="1">required</numIndex>
                            </numIndex>
                            -->
                        </items>
                        <maxitems>9999</maxitems>
                        <minitems>0</minitems>
                        <size>5</size>
                    </config>
            </eval>
            <required>
                    <label>required</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </required>
            <nullable>
                    <label>nullable</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </nullable>
            <itemsProcFunc>
                    <label>itemsProcFunc</label>
                    <config>
                        <type>input</type>
                        <size>50</size>
                        <placeholder><![CDATA[VendorName\ExtensionName\Domain\Model\Class->itemsProcFuncMethod]]></placeholder>
                        <eval>trim,nospace</eval>
                    </config>
            </itemsProcFunc>
            <foreign>
                    <label>foreign</label>
                    <onChange>reload</onChange>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </foreign>
            <foreign_table>
                    <label>foreign_table</label>
                    <displayCond>FIELD:foreign:=:1</displayCond>
                    <config>
                        <type>select</type>
                        <renderType>selectSingle</renderType>
                        <multiple>0</multiple>
                        <itemsProcFunc>K3n\Tonictypes\UserFunc\Database->populateTablesAction</itemsProcFunc>
                        <autosizemax>2</autosizemax>
                        <items type="array">
                            <numIndex index="0" type="array">
                                <numIndex index="0"></numIndex>
                                <numIndex index="1"></numIndex>
                            </numIndex>
                        </items>
                        <maxitems>1</maxitems>
                        <minitems>1</minitems>
                        <size>1</size>
                    </config>
            </foreign_table>
            <info_markers>
                    <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.available_markers</label>
                    <displayCond>FIELD:foreign:=:1</displayCond>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayAvailableMarkers</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/AvailableMarkers.html</template>
                            <includeRecord>0</includeRecord>
                            <markers>
                                <field>
                                    <type>K3n\Tonictypes\Domain\Model\Field</type>
                                    <name>field</name>
                                </field>
                                <fieldtype>
                                    <type>array</type>
                                    <name>row</name>
                                </fieldtype>
                            </markers>
                        </parameters>
                    </config>
            </info_markers>
            <foreign_table_where>
                    <label>foreign_table_where</label>
                    <displayCond>FIELD:foreign:=:1</displayCond>
                    <config>
                        <type>text</type>
                        <rows>5</rows>
                        <cols>50</cols>
                        <eval>trim</eval>
                        <placeholder>AND tablename.pid = X</placeholder>
                        <renderType>t3editor</renderType>
                        <format>php</format>
                    </config>
            </foreign_table_where>
            <include_field_values_as_options>
                    <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:include_field_values_as_options</label>
                    <displayCond>FIELD:foreign:=:1</displayCond>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </include_field_values_as_options>
        </el>
    </ROOT>
</T3DataStructure>
