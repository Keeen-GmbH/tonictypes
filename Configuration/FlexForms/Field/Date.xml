<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                <label></label>
                <config>
                    <type>user</type>
                    <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                    <parameters>
                        <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                    </parameters>
                </config>
            </info>
            <eval>
                <label>eval</label>
                <onChange>reload</onChange>
                <config>
                    <type>select</type>
                    <renderType>selectMultipleSideBySide</renderType>
                    <multiple>0</multiple>
                    <autosizemax>5</autosizemax>
                    <items type="array">
                        <!--
                        <numIndex index="0" type="array">
                            <numIndex index="0">required</numIndex>
                            <numIndex index="1">required</numIndex>
                        </numIndex>
                        -->
                    </items>
                    <maxitems>9999</maxitems>
                    <minitems>0</minitems>
                    <size>5</size>
                </config>
            </eval>
            <required>
                <label>required</label>
                <config>
                    <checkbox>1</checkbox>
                    <type>check</type>
                </config>
            </required>
            <nullable>
                <label>nullable</label>
                <config>
                    <checkbox>1</checkbox>
                    <type>check</type>
                </config>
            </nullable>
            <placeholder>
                <label>placeholder</label>
                <config>
                    <type>input</type>
                    <size>15</size>
                </config>
            </placeholder>
            <range_lower>
                <label>range -> lower</label>
                <config>
                    <type>input</type>
                    <size>15</size>
                </config>
            </range_lower>
            <range_upper>
                <label>range -> upper</label>
                <config>
                    <type>input</type>
                    <size>15</size>
                </config>
            </range_upper>
        </el>
    </ROOT>
</T3DataStructure>
