<T3DataStructure>
<ROOT>
    <type>array</type>
    <el>
        <info>
                <label></label>
                <config>
                    <type>user</type>
                    <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                    <parameters>
                        <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                    </parameters>
                </config>
        </info>
        <eval>
                <label>eval</label>
                <config>
                    <type>select</type>
                    <renderType>selectMultipleSideBySide</renderType>
                    <multiple>0</multiple>
                    <items type="array">
                        <!--
                        <numIndex index="0" type="array">
                            <numIndex index="0">required</numIndex>
                            <numIndex index="1">required</numIndex>
                        </numIndex>
                        -->
                        <numIndex index="1" type="array">
                            <numIndex index="0">trim</numIndex>
                            <numIndex index="1">trim</numIndex>
                        </numIndex>
                    </items>
                    <maxitems>9999</maxitems>
                    <minitems>0</minitems>
                </config>
        </eval>
        <required>
                <label>required</label>
                <config>
                    <checkbox>1</checkbox>
                    <type>check</type>
                </config>
        </required>
        <nullable>
                <label>nullable</label>
                <config>
                    <checkbox>1</checkbox>
                    <type>check</type>
                </config>
        </nullable>
        <cols>
                <label>cols</label>
                <config>
                    <type>input</type>
                    <size>2</size>
                    <eval>int</eval>
                    <default>30</default>
                </config>
        </cols>
        <rows>
                <label>rows</label>
                <config>
                    <type>input</type>
                    <size>2</size>
                    <eval>int</eval>
                    <default>5</default>
                </config>
        </rows>
        <placeholder>
                <label>placeholder</label>
                <config>
                    <type>input</type>
                    <size>15</size>
                </config>
        </placeholder>
        <max>
                <label>max</label>
                <config>
                    <type>input</type>
                    <size>5</size>
                    <eval>int</eval>
                    <default>2000</default>
                </config>
        </max>
        <wrap>
                <label>wrap</label>
                <config>
                    <type>select</type>
                    <renderType>selectSingle</renderType>
                    <multiple>0</multiple>
                    <items type="array">
                        <numIndex index="0" type="array">
                            <numIndex index="0">off</numIndex>
                            <numIndex index="1">off</numIndex>
                        </numIndex>
                        <numIndex index="1" type="array">
                            <numIndex index="0">virtual</numIndex>
                            <numIndex index="1">virtual</numIndex>
                        </numIndex>
                    </items>
                    <maxitems>1</maxitems>
                    <minitems>0</minitems>
                </config>
        </wrap>
    </el>
</ROOT>
</T3DataStructure>
