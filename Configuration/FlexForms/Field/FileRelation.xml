<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                    <label></label>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                        </parameters>
                    </config>
            </info>
            <allowed_default>
                    <label>allowed Default Setting</label>
                    <onChange>reload</onChange>
                    <config>
                        <type>select</type>
                        <renderType>selectSingle</renderType>
                        <multiple>0</multiple>
                        <items type="array">
                            <numIndex index="0" type="array">
                                <numIndex index="0"></numIndex>
                                <numIndex index="1"></numIndex>
                            </numIndex>
                            <numIndex index="1" type="array">
                                <numIndex index="0">common-image-types</numIndex>
                                <numIndex index="1">common-image-types</numIndex>
                            </numIndex>
                            <numIndex index="2" type="array">
                                <numIndex index="0">common-text-types</numIndex>
                                <numIndex index="1">common-text-types</numIndex>
                            </numIndex>
                            <numIndex index="3" type="array">
                                <numIndex index="0">common-media-types</numIndex>
                                <numIndex index="1">common-media-types</numIndex>
                            </numIndex>
                        </items>
                        <maxitems>1</maxitems>
                        <minitems>0</minitems>
                        <size>1</size>
                    </config>
            </allowed_default>
            <allowed>
                    <label>allowed</label>
                    <displayCond>FIELD:allowed_default:=:</displayCond>
                    <config>
                        <type>input</type>
                        <size>15</size>
                    </config>
            </allowed>
            <disallowed>
                    <label>disallowed</label>
                    <config>
                        <type>input</type>
                        <size>15</size>
                        <default>*</default>
                    </config>
            </disallowed>
            <fileUploadAllowed>
                    <label>fileUploadAllowed</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </fileUploadAllowed>
            <fileByUrlAllowed>
                    <label>fileByUrlAllowed</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </fileByUrlAllowed>
            <minitems>
                    <label>minitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>0</default>
                    </config>
            </minitems>
            <maxitems>
                    <label>maxitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>1</default>
                    </config>
            </maxitems>
            <size>
                    <label>size</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>1</default>
                    </config>
            </size>
        </el>
    </ROOT>
</T3DataStructure>
