<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                <label></label>
                <config>
                    <type>user</type>
                    <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                    <parameters>
                        <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                    </parameters>
                </config>
            </info>
            <cols>
                <label>cols</label>
                <config>
                    <type>input</type>
                    <size>3</size>
                    <eval>int</eval>
                    <default>1</default>
                    <range>
                        <lower>1</lower>
                        <upper>31</upper>
                    </range>
                </config>
            </cols>
            <readOnly>
                <label>readOnly</label>
                <config>
                    <checkbox>1</checkbox>
                    <type>check</type>
                </config>
            </readOnly>
            <!--
            No need of this
            <maximumRecordsChecked>
                <label>maximumRecordsChecked</label>
                <config>
                    <type>input</type>
                    <size>3</size>
                    <eval>int</eval>
                </config>
            </maximumRecordsChecked>
            -->
        </el>
    </ROOT>
</T3DataStructure>
