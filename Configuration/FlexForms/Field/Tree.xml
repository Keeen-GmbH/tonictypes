<T3DataStructure>
    <ROOT>
        <type>array</type>
        <el>
            <info>
                    <label></label>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayTemplate</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/Notice.html</template>
                        </parameters>
                    </config>
            </info>
            <foreign_table>
                    <label>foreign_table</label>
                    <config>
                        <type>select</type>
                        <renderType>selectSingle</renderType>
                        <multiple>0</multiple>
                        <autosizemax>2</autosizemax>
                        <items type="array">
                            <numIndex index="0" type="array">
                                <numIndex index="0">pages</numIndex>
                                <numIndex index="1">pages</numIndex>
                            </numIndex>
                            <numIndex index="1" type="array">
                                <numIndex index="0">sys_category</numIndex>
                                <numIndex index="1">sys_category</numIndex>
                            </numIndex>
                        </items>
                        <maxitems>1</maxitems>
                        <minitems>1</minitems>
                        <size>1</size>
                    </config>
            </foreign_table>
            <info_markers>
                    <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:flexform.available_markers</label>
                    <config>
                        <type>user</type>
                        <userFunc>K3n\Tonictypes\UserFunc\Template->displayAvailableMarkers</userFunc>
                        <parameters>
                            <template>EXT:tonictypes/Resources/Private/Templates/UserFunc/Field/AvailableMarkers.html</template>
                            <includeRecord>0</includeRecord>
                            <markers>
                                <field>
                                    <type>K3n\Tonictypes\Domain\Model\Field</type>
                                    <name>field</name>
                                </field>
                                <fieldtype>
                                    <type>array</type>
                                    <name>row</name>
                                </fieldtype>
                            </markers>
                        </parameters>
                    </config>
            </info_markers>
            <foreign_table_where>
                    <label>foreign_table_where</label>
                    <config>
                        <type>text</type>
                        <rows>5</rows>
                        <cols>50</cols>
                        <eval>trim</eval>
                        <placeholder>AND tablename.pid = X</placeholder>
                        <renderType>t3editor</renderType>
                        <format>php</format>
                    </config>
            </foreign_table_where>
            <showHeader>
                    <label>showHeader</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                        <default>1</default>
                    </config>
            </showHeader>
            <expandAll>
                    <label>expandAll</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </expandAll>
            <minitems>
                    <label>minitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>0</default>
                    </config>
            </minitems>
            <maxitems>
                    <label>maxitems</label>
                    <config>
                        <type>input</type>
                        <size>3</size>
                        <eval>int</eval>
                        <default>999</default>
                    </config>
            </maxitems>
            <include_field_values_as_options>
                    <label>LLL:EXT:tonictypes/Resources/Private/Language/locallang.xlf:include_field_values_as_options</label>
                    <config>
                        <checkbox>1</checkbox>
                        <type>check</type>
                    </config>
            </include_field_values_as_options>
        </el>
    </ROOT>
</T3DataStructure>
